{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emotionalinfrastructure.org/schemas/trust-receipt/authority-grant.v0.1.schema.json",
  "title": "Trust Receipt Authority Grant v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "granting_party",
    "grantee",
    "objective",
    "scope",
    "granted_at",
    "expires_at",
    "confirmation",
    "delegation",
    "status"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "grant_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"},
    "granting_party": {"$ref": "#/$defs/party"},
    "grantee": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "operator_id"],
      "properties": {
        "agent_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "operator_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "deployment_id": {"type": "string", "minLength": 1, "maxLength": 160}
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "version", "hard_constraints"],
      "properties": {
        "description": {"type": "string", "minLength": 1, "maxLength": 1000},
        "version": {"type": "string", "minLength": 1, "maxLength": 64},
        "hard_constraints": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 500},
          "uniqueItems": true,
          "maxItems": 50
        },
        "permitted_preferences": {
          "type": "array",
          "items": {"type": "string", "minLength": 1, "maxLength": 500},
          "uniqueItems": true,
          "maxItems": 50
        },
        "ambiguity_behavior": {
          "enum": ["request_confirmation", "manual_review", "deny"]
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_actions", "allowed_targets", "excluded_actions", "max_consequence_class"],
      "properties": {
        "allowed_actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,127}$"}
        },
        "allowed_targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 200}
        },
        "excluded_actions": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]{2,127}$"}
        },
        "max_consequence_class": {"enum": ["C0", "C1", "C2", "C3"]}
      }
    },
    "granted_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["threshold", "required_for"],
      "properties": {
        "threshold": {"enum": ["none", "user_confirmation", "independent_human_review"]},
        "required_for": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["C0", "C1", "C2", "C3"]}
        }
      }
    },
    "delegation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "max_depth", "permitted_recipients"],
      "properties": {
        "allowed": {"type": "boolean"},
        "max_depth": {"type": "integer", "minimum": 0, "maximum": 10},
        "permitted_recipients": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 100,
          "items": {"type": "string", "minLength": 1, "maxLength": 160}
        }
      }
    },
    "status": {"enum": ["active", "revoked", "expired", "suspended"]},
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revoked_at", "reason"],
      "properties": {
        "revoked_at": {"type": "string", "format": "date-time"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    }
  },
  "$defs": {
    "party": {
      "type": "object",
      "additionalProperties": false,
      "required": ["party_id", "display_name"],
      "properties": {
        "party_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "display_name": {"type": "string", "minLength": 1, "maxLength": 200},
        "contact_uri": {"type": "string", "format": "uri"}
      }
    }
  }
}

